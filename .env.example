# Supabase (Auth & Database)
PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-placeholder
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-placeholder

# Stripe (Payments)
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key-placeholder
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-placeholder
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret-placeholder

# Twilio (SMS Notifications)
TWILIO_ACCOUNT_SID=ACyour-twilio-account-sid-placeholder
TWILIO_AUTH_TOKEN=your-twilio-auth-token-placeholder
TWILIO_PHONE_NUMBER=+15551234567

# Plivo (SMS Notifications Alternative)
PLIVO_AUTH_ID=your-plivo-auth-id-placeholder
PLIVO_AUTH_TOKEN=your-plivo-auth-token-placeholder
PLIVO_SOURCE_NUMBER=+15559876543

# Resend (Email Notifications)
RESEND_API_KEY=re_your-resend-api-key-placeholder
RESEND_FROM_EMAIL="SplitACharter <noreply@splitacharter.boats>"

# Inngest (Background Serverless Workflows)
INNGEST_DEV=1
INNGEST_EVENT_KEY=your-inngest-event-key-placeholder
INNGEST_SIGNING_KEY=your-inngest-signing-key-placeholder

# Custom Admin Configuration
ADMIN_EMAIL=admin@splitacharter.com

